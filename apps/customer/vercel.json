{
  "installCommand": "cd ../.. && pnpm install --frozen-lockfile",
  "buildCommand": "cd ../.. && pnpm --filter @eatgood/customer build",
  "outputDirectory": "dist",
  "framework": "vite",
  "rewrites": [
    { "source": "/admin", "destination": "/api/edge-admin-403" },
    { "source": "/admin/(.*)", "destination": "/api/edge-admin-403" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
