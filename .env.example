# =============================================================================
# Eat Good Uganda — .env.example
# Copy to .env (never commit .env). Each app reads only what it needs.
# Group A variables are consumed by apps/api. Group B by the frontends.
# =============================================================================

# ---------- Group A: Backend (apps/api) ----------

NODE_ENV=development           # development | staging | production
PORT=4000
LOG_LEVEL=info                 # debug | info | warn | error

# Neon Postgres (required). Use the pooled connection string.
DATABASE_URL=postgresql://USER:PASS@ep-XXXX-pooler.region.aws.neon.tech/eatgood?sslmode=require
# Direct (non-pooled) URL for migrations only
DATABASE_URL_DIRECT=postgresql://USER:PASS@ep-XXXX.region.aws.neon.tech/eatgood?sslmode=require

# JWT — three independent secrets, one per token namespace (min 32 chars each)
JWT_CUSTOMER_SECRET=change-me-to-a-64-char-random-hex
JWT_BAKERY_SECRET=change-me-to-a-different-64-char-random-hex
JWT_SUPERADMIN_SECRET=change-me-to-yet-another-64-char-random-hex

# Token TTL (seconds for access, days for refresh)
ACCESS_TOKEN_TTL_SECONDS=900
REFRESH_TOKEN_TTL_DAYS=30

# Field-level encryption key for per-bakery payment credentials (AES-256-GCM)
# 32 random bytes, base64 encoded. Generate with: openssl rand -base64 32
CREDENTIALS_ENCRYPTION_KEY=base64-encoded-32-byte-key-here

# Super-admin IP allowlist (comma-separated CIDRs or IPs; empty = disabled)
SUPERADMIN_IP_ALLOWLIST=

# CORS origins (comma-separated, exact match)
CORS_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:5175

# Cloudinary (images)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_UPLOAD_PRESET=eatgood_unsigned

# Resend (transactional email)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
RESEND_FROM_EMAIL=no-reply@eatgooduganda.com
RESEND_REPLY_TO=support@eatgooduganda.com

# Platform URLs (used in emails, webhooks, CORS, callbacks)
PUBLIC_CUSTOMER_URL=http://localhost:5173
PUBLIC_BAKERY_ADMIN_URL=http://localhost:5174
PUBLIC_SUPERADMIN_URL=http://localhost:5175
PUBLIC_API_URL=http://localhost:4000

# ---------- Payment provider — PLATFORM-LEVEL sandbox credentials ----------
# These are for TESTING ONLY. Production credentials are stored PER BAKERY,
# encrypted in the database, and supplied by each bakery at onboarding.
# See docs/07-PAYMENTS.md for the full rationale.

# MTN MoMo — Sandbox subscription key (platform's own sandbox account)
MTN_MOMO_SANDBOX_SUBSCRIPTION_KEY=
MTN_MOMO_SANDBOX_USER_ID=
MTN_MOMO_SANDBOX_API_KEY=
MTN_MOMO_CALLBACK_HOST=https://localhost:4000
MTN_MOMO_TARGET_ENV=sandbox          # sandbox | production

# Airtel Money — Sandbox credentials
AIRTEL_SANDBOX_CLIENT_ID=
AIRTEL_SANDBOX_CLIENT_SECRET=
AIRTEL_TARGET_ENV=staging            # staging | production
AIRTEL_COUNTRY=UG
AIRTEL_CURRENCY=UGX

# Webhook HMAC secret (used to verify inbound webhooks)
WEBHOOK_HMAC_SECRET=change-me-64-char-hex

# ---------- Keepalive ----------
# URL that the GitHub Actions cron workflow pings to keep Render warm
KEEPALIVE_PING_URL=https://eatgood-api.onrender.com/health

# ---------- Rate limiting ----------
RATE_LIMIT_WINDOW_MS=900000          # 15 minutes
RATE_LIMIT_MAX_REQUESTS=300          # per window per IP
RATE_LIMIT_AUTH_MAX=10               # stricter limit on /auth/* endpoints

# ---------- Group B: Frontend apps ----------
# Only variables prefixed VITE_ are exposed to the browser bundle.

# Customer storefront (apps/customer)
VITE_API_URL=http://localhost:4000
VITE_CLOUDINARY_CLOUD_NAME=
VITE_GOOGLE_MAPS_KEY=                # optional, only if we switch to Google geolocation
VITE_SENTRY_DSN=                     # optional

# Bakery admin (apps/bakery-admin) — same VITE_API_URL, plus:
VITE_POLL_INTERVAL_MS=5000

# Super admin (apps/super-admin)
VITE_SUPERADMIN_API_URL=http://localhost:4000
